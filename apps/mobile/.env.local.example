# Copy to .env.local. Expo inlines EXPO_PUBLIC_* vars at build time.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# From GCP Console > APIs & Services > Credentials (Firebase auto-creates these
# per platform when you register iOS/Android/Web apps in the Firebase project).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Firebase Hosting URL (same one the web app uses) — NOT the raw Cloud Run
# URL. Cloud Run stays private; Hosting's rewrite is already authorized to
# invoke it, so this keeps mobile auth working with just the Firebase ID
# token, no separate Cloud Run IAM token needed.
EXPO_PUBLIC_API_URL=https://niki-app-d035f.web.app/v1