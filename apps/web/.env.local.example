# Copy to .env.local for local dev. Real values come from Firebase Console
# > Project Settings > General > Your apps > Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# GCP Console > APIs & Services > Credentials > Create API key, restricted
# to "Google Picker API". Used client-side by /vault's "Add from Drive".
NEXT_PUBLIC_GOOGLE_API_KEY=

# Local dev only — production uses /v1 via the Firebase Hosting rewrite.
NEXT_PUBLIC_API_URL=http://localhost:8080/v1
